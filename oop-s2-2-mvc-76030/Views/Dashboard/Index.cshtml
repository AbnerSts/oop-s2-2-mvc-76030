@{
    ViewData["Title"] = "Dashboard";
}

<h2>📊 Dashboard</h2>

<!-- 🔍 FILTER FORM -->
<form method="get">
    <div class="row mb-4">

        <div class="col-md-4">
            <select name="town" class="form-control">
                <option value="">All Towns</option>
                @foreach (var t in ViewBag.Towns)
                {
                    <option value="@t" selected="@(t == Context.Request.Query["town"])">@t</option>
                }
            </select>
        </div>

        <div class="col-md-4">
            <select name="risk" class="form-control">
                <option value="">All Risks</option>
                @foreach (var r in ViewBag.Risks)
                {
                    <option value="@r" selected="@(r == Context.Request.Query["risk"])">@r</option>
                }
            </select>
        </div>

        <div class="col-md-4">
            <button type="submit" class="btn btn-primary w-100">Filter</button>
        </div>

    </div>
</form>

<!-- 📊 DASHBOARD CARDS -->
<div class="row">

    <!-- INSPECTIONS THIS MONTH -->
    <div class="col-md-4 mb-3">
        <div class="card text-white bg-primary text-center">
            <div class="card-body">
                <h5>Inspections This Month</h5>
                <h2>@ViewBag.InspectionsThisMonth</h2>
            </div>
        </div>
    </div>

    <!-- FAILED INSPECTIONS -->
    <div class="col-md-4 mb-3">
        <div class="card text-white bg-danger text-center">
            <div class="card-body">
                <h5>Failed Inspections</h5>
                <h2>@ViewBag.FailedThisMonth</h2>
            </div>
        </div>
    </div>

    <!-- OVERDUE FOLLOW UPS -->
    <div class="col-md-4 mb-3">
        <div class="card text-dark bg-warning text-center">
            <div class="card-body">
                <h5>Overdue Follow-Ups</h5>
                <h2>@ViewBag.OverdueFollowUps</h2>
            </div>
        </div>
    </div>

</div>