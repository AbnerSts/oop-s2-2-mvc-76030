@model FoodSafety.Domain.Models.FollowUp

<h2>Create Follow Up</h2>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="mb-2">
        <label asp-for="InspectionId"></label>
        <select asp-for="InspectionId" asp-items="ViewBag.InspectionId" class="form-control"></select>
        <span asp-validation-for="InspectionId" class="text-danger"></span>
    </div>

    <div class="mb-2">
        <label asp-for="DueDate"></label>
        <input asp-for="DueDate" type="date" class="form-control" />
        <span asp-validation-for="DueDate" class="text-danger"></span>
    </div>

    <div class="mb-2">
        <label asp-for="Status"></label>
        <select asp-for="Status" class="form-control">
            <option value="Open">Open</option>
            <option value="Closed">Closed</option>
        </select>
    </div>

    <div class="mb-2">
        <label asp-for="ClosedDate"></label>
        <input asp-for="ClosedDate" type="date" class="form-control" />
        <span asp-validation-for="ClosedDate" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">Create</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}