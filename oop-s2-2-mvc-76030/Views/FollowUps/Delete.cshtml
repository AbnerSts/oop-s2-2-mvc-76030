@model FoodSafety.Domain.Models.FollowUp

<h2>Delete Follow Up</h2>

<h4 class="text-danger">Are you sure you want to delete this?</h4>

<div class="card p-3">
    <p><strong>Inspection:</strong> #@Model.InspectionId</p>
    <p><strong>Due Date:</strong> @Model.DueDate.ToShortDateString()</p>
    <p><strong>Status:</strong> @Model.Status</p>
</div>

<form asp-action="Delete">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>