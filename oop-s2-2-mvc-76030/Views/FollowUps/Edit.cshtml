@model FoodSafety.Domain.Models.FollowUp

<div asp-validation-summary="All" class="text-danger"></div>

<h2>Edit Follow Up</h2>

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="Id" />

    <div class="mb-2">
        <label asp-for="InspectionId"></label>
        <select asp-for="InspectionId" asp-items="ViewBag.InspectionId" class="form-control"></select>
    </div>

    <div class="mb-2">
        <label asp-for="DueDate"></label>
        <input asp-for="DueDate" type="date" class="form-control" />
    </div>

    <div class="mb-2">
        <label asp-for="Status"></label>
        <select asp-for="Status" class="form-control">
            <option>Open</option>
            <option>Closed</option>
        </select>
    </div>

    <div class="mb-2">
        <label asp-for="ClosedDate"></label>
        <input asp-for="ClosedDate" type="date" class="form-control" />
        <span asp-validation-for="ClosedDate" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-warning">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>