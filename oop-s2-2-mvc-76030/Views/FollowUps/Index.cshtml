@model IEnumerable<FoodSafety.Domain.Models.FollowUp>

<h2 class="mb-3">Follow Ups</h2>

@if (User.IsInRole("Admin") || User.IsInRole("Inspector"))
{
    <a asp-action="Create" class="btn btn-primary mb-3">Create New</a>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>Inspection</th>
            <th>Premises</th>
            <th>Due Date</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>#@item.InspectionId</td>
                <td>@item.Inspection?.Premises?.Name</td>
                <td>
                    @if (item.Status == "Open" && item.DueDate < DateTime.Now)
                    {
                        <span class="text-danger fw-bold">@item.DueDate.ToShortDateString()</span>
                    }
                    else
                    {
                        @item.DueDate.ToShortDateString()
                    }
                </td>
                <td>
                    @if (item.Status == "Open")
                    {
                        <span class="text-warning">Open</span>
                    }
                    else
                    {
                        <span class="text-success">Closed</span>
                    }
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>

                    @if (User.IsInRole("Admin") || User.IsInRole("Inspector"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>