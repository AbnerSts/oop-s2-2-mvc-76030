@model FoodSafety.Domain.Models.Inspection

<h2>Delete Inspection</h2>

<h4 class="text-danger">Are you sure you want to delete this?</h4>

<div class="card p-3">
    <p><strong>Premises:</strong> @Model.Premises?.Name</p>
    <p><strong>Date:</strong> @Model.InspectionDate.ToShortDateString()</p>
    <p><strong>Score:</strong> @Model.Score</p>
    <p><strong>Outcome:</strong> @Model.Outcome</p>
</div>

<form asp-action="Delete">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>