@model FoodSafety.Domain.Models.Inspection

<div asp-validation-summary="All" class="text-danger"></div>

<h2>Edit Inspection</h2>

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="Id" />

    <div class="mb-2">
        <label asp-for="PremisesId"></label>
        <select asp-for="PremisesId" asp-items="ViewBag.PremisesId" class="form-control"></select>
    </div>

    <div class="mb-2">
        <label asp-for="InspectionDate"></label>
        <input asp-for="InspectionDate" type="date" class="form-control" />
    </div>

    <div class="mb-2">
        <label asp-for="Score"></label>
        <input asp-for="Score" class="form-control" />
    </div>

    <div class="mb-2">
        <label asp-for="Notes"></label>
        <input asp-for="Notes" class="form-control" />
    </div>

    <button type="submit" class="btn btn-warning">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>